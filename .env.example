# BingX Streamer Configuration
# Copy this file to .env and fill in your desired values.

# The websocket URL for the BingX API
BINGX_URL=wss://open-api-swap.bingx.com/swap-market

# The trading symbol (e.g., BTC-USDT, ETH-USDT)
BINGX_SYMBOL=BTC-USDT

# The timeframe for the k-lines (e.g., 1m, 5m, 15m, 1h, 4h, 1d)
BINGX_TIMEFRAME=1m
